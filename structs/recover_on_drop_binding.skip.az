public struct Struct
{
    public fn use(self) { }
}

public fn main()
{
    var previous: iso = Struct(); // a value to reference until `s` is referenced
    var r: mut Struct = previous;
    {
        let s: iso = Struct(); // `s` has ownership
        r = s; // Create a reference to `s`
    } // ERROR `s` goes out of scope with ownership and must be recovered
    r.use(); // use `r` so that it is still alive
}
